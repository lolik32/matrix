import random
import math
import string 
 Наборы символов
lowercase_letters = string.ascii_lowercase  # 26
uppercase_letters = string.ascii_uppercase  # 26
digits = string.digits                       # 10
special_symbols = "!@#$%^&*()_+-=[]{}|;:,.<>?"  # 32
def generate_password(length=12):
   Генерация случайного пароля
    all_characters = lowercase_letters + uppercase_letters + digits + special_symbols
    return ''.join(random.choice(all_characters) for _ in range(length))
def evaluate_password_strength(password):
    Оценка стойкости пароля на основе энтропии
    char_pool_size = 0
    if any(c.islower() for c in password): char_pool_size += 26
    if any(c.isupper() for c in password): char_pool_size += 26
    if any(c.isdigit() for c in password): char_pool_size += 10
    if any(c in special_symbols for c in password): char_pool_size += 32
    entropy = len(password) * math.log2(char_pool_size or 1)
    if entropy < 30:
        strength = "Слабый"
    elif entropy < 50:
        strength = "Средний"
    else:
        strength = "Сильный"
    return round(entropy, 2), strength
 Основная программа
password = generate_password(12)
entropy_value, strength_level = evaluate_password_strength(password)
print(f"Сгенерированный пароль: {password}")
print(f"Энтропия: {entropy_value} бит")
print(f"Стойкость: {strength_level}")
