import exifread
def ap(p):
    with open(p, 'rb') as f:
        t = exifread.process_file(f)
    print("=" * 50)
    print(f"Анализ файла: {p}")
    print("=" * 50)
    r = []
    m = t.get('Image Model', None)
    if m:
        print(f" Модель устройства: {m}")
        r.append("модель устройства")
    else:
        print(" Модель устройства: не найдена")
    d = t.get('EXIF DateTimeOriginal', None)
    if not d:
        d = t.get('Image DateTime', None)
    if d:
        print(f"Дата съёмки: {d}")
        r.append("дата съёмки")
    else:
        print(" Дата съёмки: не найдена")
    gl = t.get('GPS GPSLatitude', None)
    glon = t.get('GPS GPSLongitude', None)
    if gl and glon:
        def gtd(coord):
            v = coord.values
            d = float(v[0].num) / float(v[0].den)
            m = float(v[1].num) / float(v[1].den)
            s = float(v[2].num) / float(v[2].den)
            return d + m / 60 + s / 3600
        la = gtd(gl)
        lo = gtd(glon)
        lar = t.get('GPS GPSLatitudeRef', None)
        lonr = t.get('GPS GPSLongitudeRef', None)
        if lar and str(lar).strip() == 'S':
            la = -la
        if lonr and str(lonr).strip() == 'W':
            lo = -lo
        print(f"GPS координаты: {la:.6f}, {lo:.6f}")
        r.append("GPS-координаты")
    else:
        print(" GPS координаты: не найдены")
    print("\n" + "=" * 50)
    if r:
        print("Обратите внимание:")
        print(f"Фотография содержит: {', '.join(r)}")
        print("\nИнформация может указывать на:")
        print("- Время и место съёмки")
        print("- Использованное устройство")
        print("\Перед публикацией можно удалить метаданные")
    else:
        print("Конфиденциальные данные не найдены")
    print("=" * 50)
f = "png.jpg"
try:
    ap(f)
except FileNotFoundError:
    print(f"Ошибка: Файл '{f}' не найден!")
    print("Проверьте, что файл лежит в той же папке")

