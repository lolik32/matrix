def xor_cipher(data, key):
    Шифрование/дешифрование методом XOR
    Args:
        data: исходные данные (строка или байты)
        key: ключ шифрования (строка)
    Returns:
        bytes: результат XOR операции
    Преобразуем строку в байты, если это необходимо
    if isinstance(data, str):
        data_bytes = data.encode('utf-8')
    else:
        data_bytes = data
    key_bytes = key.encode('utf-8')
    Расширяем ключ до длины данных
    extended_key = (key_bytes * (len(data_bytes) // len(key_bytes) + 1))[:len(data_bytes)]
     Применяем XOR
    return bytes(a ^ b for a, b in zip(data_bytes, extended_key))
 Исходные данные
original_text = "Прикладная информатика"
secret_key = "секрет"
 Шифрование
encrypted_data = xor_cipher(original_text, secret_key)
 Дешифрование
decrypted_text = xor_cipher(encrypted_data, secret_key).decode('utf-8')
 Вывод результатов
print(f"Исходный текст: {original_text}")
print(f"Зашифровано (hex): {encrypted_data.hex()}")
print(f"Расшифровано: {decrypted_text}")
print(f"Успех: {original_text == decrypted_text}")

